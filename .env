# Proje Ayarları
PROJECT_NAME="Vergi Tahmin DNN"
DATA_DIR="./data"
MODELS_DIR="./models"

# Model Hiperparametreleri (Makale Standartları)
ACTIVATION_FUNCTION="relu"
OPTIMIZER="adam"
LEARNING_RATE=0.01

# Eğitim Ayarları
# (Makaledeki gibi tüm veri setini tek seferde eğitmek için)
BATCH_SIZE="full" 
MAX_EPOCHS=200